{
  "name": "acseo/sylius2-prestashop-migration-plugin",
  "description": "Migrate Prestashop data into Sylius",
  "type": "sylius-plugin",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "ACSEO\\PrestashopMigrationPlugin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ACSEO\\PrestashopMigrationPlugin\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Nicolas POTIER",
      "email": "contact@acseo.fr"
    }
  ],
  "require": {
    "php": "^8.0",
    "sylius/sylius": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "symfony/phpunit-bridge": "^7.0"
  }
}
